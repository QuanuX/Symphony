{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/QuanuX/Symphony/knowledge/stav/schemas/v1/common.schema.json",
  "title": "Symphony STAV v1 common values",
  "$defs": {
    "authentication": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["method_id", "state"],
          "properties": {
            "method_id": { "$ref": "#/$defs/registeredIdentifier" },
            "state": { "const": "identified" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["reason_code", "state"],
          "properties": {
            "reason_code": { "$ref": "#/$defs/registeredIdentifier" },
            "state": { "const": "not_applicable" }
          }
        }
      ]
    },
    "configuration": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["new_digest", "previous_digest", "state"],
          "properties": {
            "new_digest": { "$ref": "#/$defs/digest" },
            "previous_digest": { "$ref": "#/$defs/digest" },
            "state": { "const": "digests" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["reason_code", "state"],
          "properties": {
            "reason_code": { "$ref": "#/$defs/registeredIdentifier" },
            "state": { "const": "not_applicable" }
          }
        }
      ]
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "opaqueReference": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:@-]{0,255}$"
    },
    "outcome": {
      "enum": ["allowed", "denied", "failed", "succeeded", "unavailable"]
    },
    "redactionClassification": {
      "enum": ["administrative_metadata", "restricted_metadata"]
    },
    "registeredIdentifier": {
      "type": "string",
      "minLength": 3,
      "maxLength": 128,
      "pattern": "^[a-z][a-z0-9-]*(\\.[a-z][a-z0-9-]*)+$"
    },
    "safeInteger": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "safeReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind"],
      "properties": {
        "id": { "$ref": "#/$defs/opaqueReference" },
        "kind": { "$ref": "#/$defs/registeredIdentifier" }
      }
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])-([0-2][0-9]|3[01])T([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]\\.[0-9]{9}Z$"
    },
    "topsId": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[1-8][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "trog": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "state"],
          "properties": {
            "id": { "$ref": "#/$defs/opaqueReference" },
            "state": { "const": "identified" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["reason_code", "state"],
          "properties": {
            "reason_code": { "$ref": "#/$defs/registeredIdentifier" },
            "state": { "const": "not_applicable" }
          }
        }
      ]
    },
    "uuid": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[47][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "uuidV4": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    }
  }
}
