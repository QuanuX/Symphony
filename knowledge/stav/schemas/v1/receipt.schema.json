{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/QuanuX/Symphony/knowledge/stav/schemas/v1/receipt.schema.json",
  "title": "symphony.stav.receipt.v1",
  "type": "object",
  "additionalProperties": false,
  "allOf": [
    {
      "if": { "properties": { "disposition": { "const": "committed" } } },
      "then": { "properties": { "commit": { "properties": { "state": { "const": "committed" } } } } }
    },
    {
      "if": { "properties": { "disposition": { "const": "rejected" } } },
      "then": { "properties": { "commit": { "properties": { "state": { "const": "not_committed" } } } } }
    }
  ],
  "required": ["candidate_digest", "commit", "disposition", "reason_code", "request_id", "schema", "tops_id"],
  "properties": {
    "candidate_digest": { "$ref": "common.schema.json#/$defs/digest" },
    "commit": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["event_digest", "event_id", "sequence", "state", "timestamp"],
          "properties": {
            "event_digest": { "$ref": "common.schema.json#/$defs/digest" },
            "event_id": { "$ref": "common.schema.json#/$defs/uuidV4" },
            "sequence": { "allOf": [{ "$ref": "common.schema.json#/$defs/safeInteger" }, { "minimum": 1 }] },
            "state": { "const": "committed" },
            "timestamp": { "$ref": "common.schema.json#/$defs/timestamp" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["reason_code", "state"],
          "properties": {
            "reason_code": { "$ref": "common.schema.json#/$defs/registeredIdentifier" },
            "state": { "const": "not_committed" }
          }
        }
      ]
    },
    "disposition": { "enum": ["committed", "rejected"] },
    "reason_code": { "$ref": "common.schema.json#/$defs/registeredIdentifier" },
    "request_id": { "$ref": "common.schema.json#/$defs/uuid" },
    "schema": { "const": "symphony.stav.receipt.v1" },
    "tops_id": { "$ref": "common.schema.json#/$defs/topsId" }
  }
}
