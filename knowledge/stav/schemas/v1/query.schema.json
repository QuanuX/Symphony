{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/QuanuX/Symphony/knowledge/stav/schemas/v1/query.schema.json",
  "title": "symphony.stav.query.v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["after_sequence", "event_classes", "limit", "outcomes", "schema", "tops_id"],
  "properties": {
    "after_sequence": { "$ref": "common.schema.json#/$defs/safeInteger" },
    "correlation_id": { "$ref": "common.schema.json#/$defs/uuid" },
    "event_classes": {
      "type": "array",
      "maxItems": 16,
      "uniqueItems": true,
      "items": { "$ref": "common.schema.json#/$defs/registeredIdentifier" }
    },
    "from_time": { "$ref": "common.schema.json#/$defs/timestamp" },
    "limit": { "type": "integer", "minimum": 1, "maximum": 1000 },
    "outcomes": {
      "type": "array",
      "maxItems": 5,
      "uniqueItems": true,
      "items": { "$ref": "common.schema.json#/$defs/outcome" }
    },
    "request_id": { "$ref": "common.schema.json#/$defs/uuid" },
    "schema": { "const": "symphony.stav.query.v1" },
    "through_sequence": { "$ref": "common.schema.json#/$defs/safeInteger" },
    "through_time": { "$ref": "common.schema.json#/$defs/timestamp" },
    "tops_id": { "$ref": "common.schema.json#/$defs/topsId" }
  }
}
