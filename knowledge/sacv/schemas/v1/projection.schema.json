{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:symphony:sacv:projection:v1",
  "title": "SACV Projection v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocol", "projection_kind", "format", "module_id", "engine_id", "engine_version", "vector_id", "canonical_registry", "contract_snapshot", "entry_count", "entries", "noncanonical", "rebuildable", "projection_digest"],
  "properties": {
    "protocol": {"const": "symphony.sacv.projection.v1"},
    "projection_kind": {"const": "registry-conformance-inventory"},
    "format": {"const": "json"},
    "module_id": {"const": "sacv-engine"},
    "engine_id": {"const": "symphony-sacv"},
    "engine_version": {"type": "string", "minLength": 1, "maxLength": 64, "pattern": "^[0-9A-Za-z.+-]+$"},
    "vector_id": {"const": "sacv"},
    "canonical_registry": {"$ref": "#/$defs/file"},
    "contract_snapshot": {"$ref": "#/$defs/snapshot"},
    "entry_count": {"type": "integer", "minimum": 0, "maximum": 256},
    "entries": {"type": "array", "maxItems": 256, "items": {"$ref": "#/$defs/projected_entry"}},
    "noncanonical": {"const": true},
    "rebuildable": {"const": true},
    "projection_digest": {"$ref": "#/$defs/digest"}
  },
  "$defs": {
    "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "file": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "size", "digest"],
      "properties": {
        "path": {"type": "string", "minLength": 1, "maxLength": 4096},
        "size": {"type": "integer", "minimum": 0, "maximum": 4194304},
        "digest": {"$ref": "#/$defs/digest"}
      }
    },
    "snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["digest", "files"],
      "properties": {
        "digest": {"$ref": "#/$defs/digest"},
        "files": {"type": "array", "minItems": 1, "maxItems": 64, "items": {"$ref": "#/$defs/file"}}
      }
    },
    "projected_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["api_id", "title", "owner", "path", "openapi", "api_version", "audience", "transport_profile", "security_profile", "publication_state", "sdk_state", "status", "notes", "entry_digest", "contract_digest", "operation_count"],
      "properties": {
        "api_id": {"$ref": "registry-entry.schema.json#/properties/api_id"},
        "title": {"$ref": "registry-entry.schema.json#/properties/title"},
        "owner": {"$ref": "registry-entry.schema.json#/properties/owner"},
        "path": {"$ref": "registry-entry.schema.json#/properties/path"},
        "openapi": {"$ref": "registry-entry.schema.json#/properties/openapi"},
        "api_version": {"$ref": "registry-entry.schema.json#/properties/api_version"},
        "audience": {"$ref": "registry-entry.schema.json#/properties/audience"},
        "transport_profile": {"$ref": "registry-entry.schema.json#/properties/transport_profile"},
        "security_profile": {"$ref": "registry-entry.schema.json#/properties/security_profile"},
        "publication_state": {"$ref": "registry-entry.schema.json#/properties/publication_state"},
        "sdk_state": {"$ref": "registry-entry.schema.json#/properties/sdk_state"},
        "status": {"$ref": "registry-entry.schema.json#/properties/status"},
        "notes": {"$ref": "registry-entry.schema.json#/properties/notes"},
        "entry_digest": {"$ref": "#/$defs/digest"},
        "contract_digest": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/digest"}]},
        "operation_count": {"type": "integer", "minimum": 0, "maximum": 9007199254740991}
      }
    }
  }
}
