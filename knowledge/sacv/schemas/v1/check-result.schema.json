{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:symphony:sacv:check-result:v1",
  "title": "SACV Check Result v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocol", "registry", "contract_snapshot", "expected_registry_matches", "entries_checked", "documents_checked", "operations_checked", "evidence", "summary", "read_only", "canonical_apply_enabled"],
  "properties": {
    "protocol": {"const": "symphony.sacv.check-result.v1"},
    "registry": {"$ref": "#/$defs/file"},
    "contract_snapshot": {"$ref": "#/$defs/snapshot"},
    "expected_registry_matches": {"oneOf": [{"type": "boolean"}, {"type": "null"}]},
    "entries_checked": {"type": "integer", "minimum": 0, "maximum": 256},
    "documents_checked": {"type": "integer", "minimum": 0, "maximum": 256},
    "operations_checked": {"type": "integer", "minimum": 0, "maximum": 9007199254740991},
    "evidence": {"type": "array", "maxItems": 1024, "items": {"$ref": "#/$defs/evidence"}},
    "summary": {"$ref": "#/$defs/summary"},
    "read_only": {"const": true},
    "canonical_apply_enabled": {"const": false}
  },
  "$defs": {
    "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "file": {
      "type": "object", "additionalProperties": false,
      "required": ["path", "size", "digest"],
      "properties": {
        "path": {"type": "string", "minLength": 1, "maxLength": 4096},
        "size": {"type": "integer", "minimum": 0, "maximum": 4194304},
        "digest": {"$ref": "#/$defs/digest"}
      }
    },
    "snapshot": {
      "type": "object", "additionalProperties": false,
      "required": ["digest", "files"],
      "properties": {
        "digest": {"$ref": "#/$defs/digest"},
        "files": {"type": "array", "minItems": 1, "maxItems": 64, "items": {"$ref": "#/$defs/file"}}
      }
    },
    "evidence": {
      "type": "object", "additionalProperties": false,
      "required": ["severity", "code", "path", "detail"],
      "properties": {
        "severity": {"enum": ["warning", "violation"]},
        "code": {"type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._:-]+$"},
        "path": {"type": "string", "minLength": 1, "maxLength": 4096},
        "detail": {"type": "string", "minLength": 1, "maxLength": 65536}
      }
    },
    "summary": {
      "type": "object", "additionalProperties": false,
      "required": ["pass", "warning", "violation", "state"],
      "properties": {
        "pass": {"type": "integer", "minimum": 0, "maximum": 9007199254740991},
        "warning": {"type": "integer", "minimum": 0, "maximum": 1024},
        "violation": {"type": "integer", "minimum": 0, "maximum": 1024},
        "state": {"enum": ["valid", "invalid"]}
      }
    }
  }
}
