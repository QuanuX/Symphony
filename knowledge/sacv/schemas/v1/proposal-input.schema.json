{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:symphony:sacv:proposal-input:v1",
  "title": "SACV Proposal Input v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["repository", "session_ref", "context_ref", "created_at", "expires_at", "operation"],
  "properties": {
    "repository": {"$ref": "#/$defs/repository"},
    "session_ref": {"$ref": "#/$defs/optional_token"},
    "context_ref": {"$ref": "#/$defs/optional_token"},
    "created_at": {"$ref": "#/$defs/utc"},
    "expires_at": {"$ref": "#/$defs/utc"},
    "operation": {"$ref": "#/$defs/operation"}
  },
  "$defs": {
    "token": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "optional_token": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/token"}]},
    "printable_256": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[^\\u0000-\\u001F\\u007F]+$"
    },
    "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "utc": {
      "type": "string",
      "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])-([0-2][0-9]|3[01])T([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]Z$"
    },
    "revision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scheme", "value"],
      "properties": {
        "scheme": {"$ref": "#/$defs/token"},
        "value": {"$ref": "#/$defs/printable_256"}
      }
    },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository_id", "revision", "worktree_id", "tree_digest"],
      "properties": {
        "repository_id": {"$ref": "#/$defs/printable_256"},
        "revision": {"$ref": "#/$defs/revision"},
        "worktree_id": {"$ref": "#/$defs/token"},
        "tree_digest": {"$ref": "#/$defs/digest"}
      }
    },
    "operation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "expected_registry_digest", "expected_entry_digest", "entry"],
      "properties": {
        "type": {"enum": ["register_contract", "replace_contract"]},
        "expected_registry_digest": {"$ref": "#/$defs/digest"},
        "expected_entry_digest": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/digest"}]},
        "entry": {"$ref": "registry-entry.schema.json"}
      }
    }
  }
}
