{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:symphony:sclv:recovery-input:v3",
  "title": "SCLV ephemeral recovery reconciliation input v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["journal", "journal_digest", "observed_state", "proposal_input", "recovery_reason"],
  "properties": {
    "journal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "format_version", "session_id", "source_operation", "base_revision",
        "intended_surfaces", "started_at", "known_change_request",
        "known_revision", "local_state"
      ],
      "properties": {
        "format_version": {"const": 1},
        "session_id": {"$ref": "#/$defs/token"},
        "source_operation": {"$ref": "#/$defs/token"},
        "base_revision": {"$ref": "#/$defs/revision"},
        "intended_surfaces": {
          "type": "array", "minItems": 1, "maxItems": 1024,
          "uniqueItems": true, "items": {"$ref": "#/$defs/path"}
        },
        "started_at": {"$ref": "#/$defs/timestamp"},
        "known_change_request": {
          "type": "object", "additionalProperties": false,
          "required": ["state", "provider", "id", "reference", "absence_reason"],
          "properties": {
            "state": {"enum": ["present", "not_applicable"]},
            "provider": {"$ref": "#/$defs/token"},
            "id": {"$ref": "#/$defs/text"},
            "reference": {"$ref": "#/$defs/text"},
            "absence_reason": {"$ref": "#/$defs/text"}
          }
        },
        "known_revision": {"$ref": "#/$defs/revision"},
        "local_state": {"enum": ["pending", "resumable", "abandonable"]}
      }
    },
    "journal_digest": {"$ref": "#/$defs/digest"},
    "observed_state": {"enum": ["still_open", "closed_without_merge", "merged_already_recorded", "merged_unrecorded", "indeterminate"]},
    "proposal_input": {"oneOf": [{"type": "null"}, {"$ref": "urn:symphony:sclv:proposal-input:v3"}]},
    "recovery_reason": {"$ref": "#/$defs/text"}
  },
  "$defs": {
    "token": {"type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._:-]+$"},
    "text": {"type": "string", "minLength": 1, "maxLength": 4096},
    "timestamp": {"type": "string", "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])-([0-2][0-9]|3[01])T([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]Z$"},
    "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "path": {"type": "string", "minLength": 1, "maxLength": 4096, "pattern": "^(?!/)(?!.*(?:^|/)\\.{1,2}(?:/|$))(?!.*//)(?!.*\\\\)(?!.*[\\u0000-\\u001F\\u007F])[^/]+(?:/[^/]+)*$"},
    "revision": {
      "type": "object", "additionalProperties": false,
      "required": ["scheme", "value"],
      "properties": {
        "scheme": {"$ref": "#/$defs/token"},
        "value": {"type": "string", "minLength": 1, "maxLength": 256}
      }
    }
  }
}
