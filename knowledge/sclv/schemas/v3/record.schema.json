{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:symphony:sclv:record:v3",
  "title": "Symphony provider-neutral SCLV record v3",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_id", "record_version", "title", "status", "date",
    "change_started_at", "change_completed_at", "recorded_at",
    "recording_disposition", "recovery_reason", "change_type",
    "change_request_state", "change_request_provider", "change_request_id",
    "change_request_reference", "change_request_absence_reason",
    "revision_scheme", "revision_value", "tree_digest",
    "ratification_subject", "ratification_permission", "ratification_method",
    "ratification_evidence_reference", "ratification_evidence_digest",
    "affected_surfaces", "skvi_references", "change_summary",
    "relationship_changes", "doctrine_changes", "compatibility_consequences",
    "publication_consequences", "projection_consequences", "evidence",
    "non_authorizations", "notes"
  ],
  "properties": {
    "record_id": {"type": "string", "pattern": "^SCLV-CHG-[A-Za-z0-9][A-Za-z0-9._:-]{7,95}$"},
    "record_version": {"const": 3},
    "title": {"$ref": "#/$defs/text"},
    "status": {"const": "canonical"},
    "date": {"type": "string", "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])-([0-2][0-9]|3[01])$"},
    "change_started_at": {"$ref": "#/$defs/timestamp"},
    "change_completed_at": {"$ref": "#/$defs/timestamp"},
    "recorded_at": {"$ref": "#/$defs/timestamp"},
    "recording_disposition": {"enum": ["post_merge", "late_recovery"]},
    "recovery_reason": {"$ref": "#/$defs/text"},
    "change_type": {"$ref": "#/$defs/token"},
    "change_request_state": {"enum": ["present", "not_applicable"]},
    "change_request_provider": {"$ref": "#/$defs/token"},
    "change_request_id": {"$ref": "#/$defs/text"},
    "change_request_reference": {"$ref": "#/$defs/text"},
    "change_request_absence_reason": {"$ref": "#/$defs/text"},
    "revision_scheme": {"$ref": "#/$defs/token"},
    "revision_value": {"$ref": "#/$defs/revision"},
    "tree_digest": {"$ref": "#/$defs/digest"},
    "ratification_subject": {"$ref": "#/$defs/text"},
    "ratification_permission": {"$ref": "#/$defs/text"},
    "ratification_method": {"$ref": "#/$defs/text"},
    "ratification_evidence_reference": {"$ref": "#/$defs/text"},
    "ratification_evidence_digest": {"$ref": "#/$defs/digest"},
    "affected_surfaces": {"$ref": "#/$defs/pathList"},
    "skvi_references": {"$ref": "#/$defs/pathList"},
    "change_summary": {"$ref": "#/$defs/longText"},
    "relationship_changes": {"$ref": "#/$defs/longText"},
    "doctrine_changes": {"$ref": "#/$defs/longText"},
    "compatibility_consequences": {"$ref": "#/$defs/longText"},
    "publication_consequences": {"$ref": "#/$defs/longText"},
    "projection_consequences": {"$ref": "#/$defs/longText"},
    "evidence": {"$ref": "#/$defs/textList"},
    "non_authorizations": {"$ref": "#/$defs/textList"},
    "notes": {"$ref": "#/$defs/longText"}
  },
  "$defs": {
    "token": {"type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._:-]+$"},
    "text": {"type": "string", "minLength": 1, "maxLength": 4096},
    "longText": {"type": "string", "minLength": 1, "maxLength": 65536},
    "revision": {"type": "string", "minLength": 1, "maxLength": 256},
    "timestamp": {"type": "string", "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])-([0-2][0-9]|3[01])T([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]Z$"},
    "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "path": {"type": "string", "minLength": 1, "maxLength": 4096, "pattern": "^(?!/)(?!.*(?:^|/)\\.{1,2}(?:/|$))(?!.*//)(?!.*\\\\)(?!.*[\\u0000-\\u001F\\u007F])[^/]+(?:/[^/]+)*$"},
    "pathList": {"type": "array", "minItems": 1, "maxItems": 1024, "uniqueItems": true, "items": {"$ref": "#/$defs/path"}},
    "textList": {"type": "array", "minItems": 1, "maxItems": 1024, "uniqueItems": true, "items": {"$ref": "#/$defs/text"}}
  }
}
