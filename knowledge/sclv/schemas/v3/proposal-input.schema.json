{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:symphony:sclv:proposal-input:v3",
  "title": "SCLV v3 proposal input",
  "type": "object",
  "additionalProperties": false,
  "required": ["repository", "session_ref", "context_ref", "proposal_expires_at", "record", "provider_evidence"],
  "properties": {
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository_id", "revision", "worktree_id", "tree_digest"],
      "properties": {
        "repository_id": {"type": "string", "minLength": 1, "maxLength": 256},
        "revision": {
          "type": "object",
          "additionalProperties": false,
          "required": ["scheme", "value"],
          "properties": {
            "scheme": {"$ref": "#/$defs/token"},
            "value": {"type": "string", "minLength": 1, "maxLength": 256}
          }
        },
        "worktree_id": {"$ref": "#/$defs/token"},
        "tree_digest": {"$ref": "#/$defs/digest"}
      }
    },
    "session_ref": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/token"}]},
    "context_ref": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/token"}]},
    "proposal_expires_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])-([0-2][0-9]|3[01])T([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]Z$"
    },
    "record": {"$ref": "urn:symphony:sclv:record:v3"},
    "provider_evidence": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "items": {"$ref": "urn:symphony:knowledge:provider-evidence:v1"}
    }
  },
  "$defs": {
    "token": {"type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._:-]+$"},
    "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
  }
}
