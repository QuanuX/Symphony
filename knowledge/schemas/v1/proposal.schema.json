{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:symphony:knowledge:proposal:v1",
  "title": "Symphony knowledge proposal v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocol", "proposal_id", "proposal_digest", "module_id", "engine_id",
    "engine_version", "vector_id", "contract_versions", "repository",
    "session_ref", "context_ref", "read_set", "write_set", "operations",
    "validation", "authority", "created_at", "expires_at", "canonical_apply_enabled"
  ],
  "properties": {
    "protocol": {"const": "symphony.knowledge.proposal.v1"},
    "proposal_id": {"$ref": "#/$defs/token"},
    "proposal_digest": {"$ref": "#/$defs/digest"},
    "module_id": {"$ref": "#/$defs/token"},
    "engine_id": {"$ref": "#/$defs/token"},
    "engine_version": {"$ref": "#/$defs/version"},
    "vector_id": {"$ref": "#/$defs/token"},
    "contract_versions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1, "maxLength": 256}
    },
    "repository": {"$ref": "#/$defs/repository"},
    "session_ref": {"$ref": "#/$defs/optional_token"},
    "context_ref": {"$ref": "#/$defs/optional_token"},
    "read_set": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4096,
      "items": {"$ref": "#/$defs/file"}
    },
    "write_set": {
      "type": "array",
      "minItems": 1,
      "maxItems": 256,
      "items": {"$ref": "#/$defs/write"}
    },
    "operations": {
      "type": "array",
      "minItems": 1,
      "maxItems": 256,
      "items": {"$ref": "#/$defs/operation"}
    },
    "validation": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4096,
      "items": {"$ref": "#/$defs/validation"}
    },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": ["caller_declared_operation", "engine_decided_membership", "ratified"],
      "properties": {
        "caller_declared_operation": {"type": "boolean"},
        "engine_decided_membership": {"const": false},
        "ratified": {"const": false}
      }
    },
    "created_at": {"$ref": "#/$defs/utc"},
    "expires_at": {"$ref": "#/$defs/utc"},
    "canonical_apply_enabled": {"const": false}
  },
  "$defs": {
    "token": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "optional_token": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/token"}]},
    "version": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[0-9A-Za-z.+-]+$"
    },
    "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "path": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4096,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.{1,2}(?:/|$))(?!.*//)(?!.*\\\\)(?!.*[\\u0000-\\u001F\\u007F])[^/]+(?:/[^/]+)*$"
    },
    "utc": {
      "type": "string",
      "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])-([0-2][0-9]|3[01])T([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]Z$"
    },
    "revision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scheme", "value"],
      "properties": {
        "scheme": {"$ref": "#/$defs/token"},
        "value": {"$ref": "#/$defs/printable_256"}
      }
    },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository_id", "revision", "worktree_id", "tree_digest"],
      "properties": {
        "repository_id": {"$ref": "#/$defs/printable_256"},
        "revision": {"$ref": "#/$defs/revision"},
        "worktree_id": {"$ref": "#/$defs/token"},
        "tree_digest": {"$ref": "#/$defs/digest"}
      }
    },
    "file": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "size", "digest"],
      "properties": {
        "path": {"$ref": "#/$defs/path"},
        "size": {"type": "integer", "minimum": 0, "maximum": 9007199254740991},
        "digest": {"$ref": "#/$defs/digest"}
      }
    },
    "write": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_path", "expected_prior_digest", "desired_change_digest"],
      "properties": {
        "target_path": {"$ref": "#/$defs/path"},
        "expected_prior_digest": {"$ref": "#/$defs/digest"},
        "desired_change_digest": {"$ref": "#/$defs/digest"}
      }
    },
    "operation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operation_id", "type", "target_path", "expected_state_digest", "desired_change_digest", "data"],
      "properties": {
        "operation_id": {"$ref": "#/$defs/token"},
        "type": {"$ref": "#/$defs/token"},
        "target_path": {"$ref": "#/$defs/path"},
        "expected_state_digest": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/digest"}]},
        "desired_change_digest": {"$ref": "#/$defs/digest"},
        "data": {
          "type": "object",
          "maxProperties": 256,
          "propertyNames": {"type": "string", "maxLength": 65536},
          "additionalProperties": {"$ref": "#/$defs/value"}
        }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "outcome", "detail"],
      "properties": {
        "code": {"$ref": "#/$defs/token"},
        "outcome": {"enum": ["pass", "warning", "violation"]},
        "detail": {"$ref": "#/$defs/field"}
      }
    },
    "printable_256": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[^\\u0000-\\u001F\\u007F]+$"
    },
    "field": {
      "type": "string",
      "minLength": 1,
      "maxLength": 65536,
      "pattern": "^(?![\\s\\S]*[\\u0000-\\u0009\\u000B-\\u001F\\u007F])[\\s\\S]+$"
    },
    "value": {
      "oneOf": [
        {"type": "null"},
        {"type": "boolean"},
        {"type": "integer", "minimum": -9007199254740991, "maximum": 9007199254740991},
        {"$ref": "#/$defs/field"},
        {
          "type": "array",
          "maxItems": 16384,
          "items": {"$ref": "#/$defs/value"}
        },
        {
          "type": "object",
          "maxProperties": 16384,
          "propertyNames": {"type": "string", "maxLength": 65536},
          "additionalProperties": {"$ref": "#/$defs/value"}
        }
      ]
    }
  }
}
