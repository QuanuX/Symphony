{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:symphony:sodv:observed-state:v1",
  "title": "SODV observed publication state v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["authorization_record_id", "observed_at", "source_reference", "units"],
  "properties": {
    "authorization_record_id": {"type": "string", "pattern": "^SODV-REL-[A-Z0-9][A-Z0-9._:-]{2,95}$"},
    "observed_at": {"type": "string", "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])-([0-2][0-9]|3[01])T([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]Z$"},
    "source_reference": {"type": "string", "minLength": 1, "maxLength": 4096},
    "units": {"type": "array", "minItems": 1, "maxItems": 128, "items": {"$ref": "#/$defs/unit"}}
  },
  "$defs": {
    "revision": {"type": "string", "pattern": "^([0-9a-f]{40}|[0-9a-f]{64})$"},
    "optional_revision": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/revision"}]},
    "optional_text": {"oneOf": [{"type": "null"}, {"type": "string", "minLength": 1, "maxLength": 512}]},
    "unit": {
      "type": "object", "additionalProperties": false,
      "required": ["coordinate", "version", "tag", "tag_object", "tag_target_revision", "public_state", "public_content_digest", "public_metadata_digest", "evidence_digest"],
      "properties": {
        "coordinate": {"type": "string", "minLength": 1, "maxLength": 4096},
        "version": {"type": "string", "pattern": "^v(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(-[0-9A-Za-z.-]+)?(\\+[0-9A-Za-z.-]+)?$"},
        "tag": {"type": "string", "minLength": 1, "maxLength": 4096},
        "tag_object": {"$ref": "#/$defs/optional_revision"},
        "tag_target_revision": {"$ref": "#/$defs/optional_revision"},
        "public_state": {"enum": ["not_observed", "resolved", "failed"]},
        "public_content_digest": {"$ref": "#/$defs/optional_text"},
        "public_metadata_digest": {"$ref": "#/$defs/optional_text"},
        "evidence_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
      }
    }
  }
}
