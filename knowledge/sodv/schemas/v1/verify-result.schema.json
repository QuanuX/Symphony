{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:symphony:sodv:verify-result:v1",
  "title": "SODV verification result v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocol", "authorization_record_id", "canonical_completion_record", "observed_state_digest", "verification_state", "units", "read_only", "noncanonical", "engine_declares_completion", "result_digest"],
  "properties": {
    "protocol": {"const": "symphony.sodv.verify-result.v1"},
    "authorization_record_id": {"type": "string", "minLength": 1, "maxLength": 128},
    "canonical_completion_record": {"oneOf": [{"type": "null"}, {"type": "string", "minLength": 1, "maxLength": 128}]},
    "observed_state_digest": {"$ref": "#/$defs/digest"},
    "verification_state": {"enum": ["authorized_unpublished", "published_waiting_evidence", "completion_candidate", "verified_completed", "blocked_mismatch"]},
    "units": {"type": "array", "minItems": 1, "maxItems": 128, "items": {"$ref": "#/$defs/unit"}},
    "read_only": {"const": true},
    "noncanonical": {"const": true},
    "engine_declares_completion": {"const": false},
    "result_digest": {"$ref": "#/$defs/digest"}
  },
  "$defs": {
    "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "unit": {"type": "object", "additionalProperties": false, "required": ["coordinate", "version", "tag", "state", "detail"], "properties": {"coordinate": {"type": "string", "minLength": 1, "maxLength": 4096}, "version": {"type": "string", "minLength": 1, "maxLength": 128}, "tag": {"type": "string", "minLength": 1, "maxLength": 4096}, "state": {"enum": ["tag_absent", "tag_matches_waiting", "completion_ready", "completed_matches", "mismatch"]}, "detail": {"type": "string", "minLength": 1, "maxLength": 65536}}}
  }
}
