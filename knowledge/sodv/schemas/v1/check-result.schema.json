{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:symphony:sodv:check-result:v1",
  "title": "SODV ledger check result v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocol", "ledger", "contract_snapshot", "expected_ledger_matches", "records_checked", "transactions_checked", "evidence", "summary", "read_only", "canonical_apply_enabled"],
  "properties": {
    "protocol": {"const": "symphony.sodv.check-result.v1"},
    "ledger": {"$ref": "#/$defs/file"},
    "contract_snapshot": {"$ref": "#/$defs/snapshot"},
    "expected_ledger_matches": {"type": "boolean"},
    "records_checked": {"type": "integer", "minimum": 0, "maximum": 4096},
    "transactions_checked": {"type": "integer", "minimum": 0, "maximum": 4096},
    "evidence": {"type": "array", "maxItems": 2048, "items": {"$ref": "#/$defs/evidence"}},
    "summary": {"$ref": "#/$defs/summary"},
    "read_only": {"const": true},
    "canonical_apply_enabled": {"const": false}
  },
  "$defs": {
    "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "file": {"type": "object", "additionalProperties": false, "required": ["path", "size", "digest"], "properties": {"path": {"type": "string", "minLength": 1, "maxLength": 4096}, "size": {"type": "integer", "minimum": 0, "maximum": 4194304}, "digest": {"$ref": "#/$defs/digest"}}},
    "snapshot": {"type": "object", "additionalProperties": false, "required": ["digest", "files"], "properties": {"digest": {"$ref": "#/$defs/digest"}, "files": {"type": "array", "minItems": 1, "maxItems": 64, "items": {"$ref": "#/$defs/file"}}}},
    "evidence": {"type": "object", "additionalProperties": false, "required": ["severity", "code", "path", "line", "detail"], "properties": {"severity": {"enum": ["warning", "violation"]}, "code": {"type": "string", "minLength": 1, "maxLength": 128}, "path": {"const": "knowledge/sodv/RELEASES.md"}, "line": {"type": "integer", "minimum": 0, "maximum": 9007199254740991}, "detail": {"type": "string", "minLength": 1, "maxLength": 65536}}},
    "summary": {"type": "object", "additionalProperties": false, "required": ["state", "passes", "warnings", "violations"], "properties": {"state": {"enum": ["valid", "invalid"]}, "passes": {"type": "integer", "minimum": 0}, "warnings": {"type": "integer", "minimum": 0}, "violations": {"type": "integer", "minimum": 0}}}
  }
}
